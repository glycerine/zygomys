// should be able to set on the output of arrayidx
(def ar [4 5 6])
(def i 2)
(set (arrayidx ar [i]) 99)
(assert {ar[i] == 99})
(= {ar[i]} 1010101)

// series of infix ;-separated expressions should all be evaluated
{ b = 2; d = 4 }
(assert {b+2 == d})

// new
(def x 1)
(defn g [] (set x 2))
(defn f [] (let [x 42] (g)))
(f)
(assert (== x 2))

(defn g [] (set x 2))
(defn f [] (let [x 42] (g) x))
(assert (== (f) 42))

// we were still doing some dynamic scoping at the end. verify that is gone now:
(defn staticScopeReadProbe [] localStaticScopeProbe)
(defn staticScopeCaller [] (let [localStaticScopeProbe 42] (staticScopeReadProbe)))

(expectError "symbol `localStaticScopeProbe` not found" (staticScopeCaller))
